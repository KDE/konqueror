#~ "  kfmclient openProfile 'profile' ['url']\n"
#~ "            # Открывает окно, используя заданный профиль.\n"
#~ "            #   'profile' находится в ~/.kde/share/apps/konqueror/"
#~ "profiles.\n"
#~ "            #   'url' - это необязательный параметр - URL, который вы "
#~ "хотите открыть.\n"
#~ "\n"

