#: history_module/kcmhistory.cpp:54
#, kde-format
msgid ""
"Action to carry out when opening an URL from history:<dl><dl><dt>Auto:</"
"dt><dd>opens the URL in a new tab unless the current tab is empty or an "
"intro page</dd><dt>Open URL in a new tab:</dt><dd>always opens the URL in a "
"new tab</dd><dt>Open URL in current tab:</dt><dd>always opens the URL in the "
"current tab</dd><dt>Open URL in new window:</dt><dd>always opens the URL in "
"a new window</dd></dl>"
msgstr ""
"Akcia, ktorá sa vykoná pri otváraní URL z histórie:<dl><dl><dt>Automaticky:</"
"dt><dd>otvorí URL v novej karte, pokiaľ aktuálna karta nie je prázdna alebo "
"úvodná stránka</dd><dt>Otvoriť URL v novej karte:</dt><dd>vždy otvorí URL v "
"novej karte</dd><dt>Otvoriť URL v aktuálnej karte:</dt><dd>vždy otvorí URL v "
"aktuálnej karte</dd><dt>Otvoriť URL v novom okne:</dt><dd>vždy otvorí URL v "
"novom okne</dd></dl>"

